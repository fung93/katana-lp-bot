# Copy to .env and fill in. .env is gitignored - never commit it.
# This bot is signal-only: no private keys are needed or accepted anywhere.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# YOUR numeric Telegram user ID (get it from @userinfobot).
# The bot ignores every other user.
TELEGRAM_ALLOWED_USER_ID=

# Neon Postgres POOLED connection string (note the "-pooler" host), e.g.
# postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Katana JSON-RPC endpoint (chain 747474). An HTTPS read endpoint is enough.
RPC_URL=

# Optional: override the pool. Defaults to vbUSDC/vbETH 0.05%.
# POOL_ADDRESS=0x2A2C512beAA8eB15495726C235472D82EFFB7A6B
